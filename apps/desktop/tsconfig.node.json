{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "electron-vite/node"]
  },
  "include": [
    "electron.vite.config.*",
    "electron/**/*",
    "postcss.config.*",
    "tailwind.config.*"
  ]
}
