# Copy this file to .env and fill in your values.
# pydantic-settings reads .env automatically.

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: gemini | mock
# Default: gemini  (falls back to mock when GEMINI_API_KEY is absent)
LLM_PROVIDER=gemini

# Gemini API key — get one at https://aistudio.google.com/app/apikey
# Leave blank to use the mock provider (no AI calls, fixture data only)
GEMINI_API_KEY=AIzaSyCJS_X3Vr-mkikz1O5QR6Wwti4aYM7WRrQ

# Gemini model to use (default: gemini-2.0-flash)
# Other options: gemini-1.5-flash, gemini-1.5-pro
GEMINI_MODEL=gemini-2.0-flash

# ── Asset Provider ────────────────────────────────────────────────────────────
# Options: pexels | pixabay | unsplash | mock
# Default: mock  (gradient fallback — no API calls)
ASSET_PROVIDER=mock

# Pexels API key — get one at https://www.pexels.com/api/
PEXELS_API_KEY=

# Pixabay API key — get one at https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# Unsplash access key — get one at https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8765
HOST=127.0.0.1
LOG_LEVEL=info
